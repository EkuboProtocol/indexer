{
  "name": "@ekubo/indexer",
  "private": true,
  "version": "0.0.1",
  "description": "Indexes Ekubo data into a Postgres database",
  "scripts": {
    "rhc:sepolia": "NETWORK=rhc-sepolia bun src/evm.ts",
    "rhc:mainnet": "NETWORK=rhc-mainnet bun src/evm.ts",
    "base:sepolia": "NETWORK=base-sepolia bun src/evm.ts",
    "base:mainnet": "NETWORK=base-mainnet bun src/evm.ts",
    "arb:sepolia": "NETWORK=arb-sepolia bun src/evm.ts",
    "arb:mainnet": "NETWORK=arb-mainnet bun src/evm.ts",
    "polygon:mainnet": "NETWORK=polygon-mainnet bun src/evm.ts",
    "bsc:mainnet": "NETWORK=bsc-mainnet bun src/evm.ts",
    "eth:mainnet": "NETWORK=mainnet bun src/evm.ts",
    "mega:mainnet": "NETWORK=megaeth bun src/evm.ts",
    "monad:mainnet": "NETWORK=monad bun src/evm.ts",
    "eth:sepolia": "NETWORK=sepolia bun src/evm.ts",
    "starknet:mainnet": "NETWORK=mainnet bun src/starknet.ts",
    "starknet:sepolia": "NETWORK=sepolia bun src/starknet.ts",
    "sync-tokens": "bun scripts/sync-tokens.ts",
    "sync-token-prices": "bun scripts/sync-token-prices.ts",
    "migrate": "bun scripts/migrate.ts"
  },
  "author": "Moody Salem",
  "type": "module",
  "engines": {
    "bun": ">=1.3"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.16",
    "@types/bun": "^1.3.13"
  },
  "dependencies": {
    "@apibara/evm": "^2.1.4",
    "@apibara/evm-rpc": "^2.1.4",
    "@apibara/protocol": "^2.1.3",
    "@apibara/starknet": "^2.1.4",
    "bottleneck": "^2.19.5",
    "dotenv": "^17.4.2",
    "postgres": "^3.4.9",
    "postgres-shift": "^0.1.0",
    "viem": "^2.48.11",
    "winston": "^3.19.0"
  }
}
